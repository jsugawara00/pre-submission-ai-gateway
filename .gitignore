# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# 設計ドキュメントの原本（docs/等に配置済みのため重複コミットを避ける）
/settingfile

# typescript
*.tsbuildinfo
next-env.d.ts

# 暗号化済みアップロードPDFの保存先（gitには含めない）
/storage

# 開発サーバーの一時ログ
dev.log

# 業務秘密事項（GitHubに含めない。ローカル限定）
conceal.md

# 照合精度ルール（業務ノウハウ＝守秘。GitHubに含めない。ローカル限定）
rulebook.md

# rulebook の原本バックアップ（構造整理前のコピー。守秘・ローカル限定）
copy_rulebook.md

# 脆弱性ブレークダウン用の崩しコピー（原本のコピー。ローカル限定）
/test-cases

# Python のキャッシュ（フィクスチャ生成スクリプト由来。コミットしない）
__pycache__/
*.pyc

# 一時ファイル（観察ログ・E2Eのbody/HTML等。ローカル限定）
tmp_*

# 崩しテスト用スクリプト（崩し生成・実験実行。ローカル限定）
/scripts/experiment-cosmetic.ts
/scripts/make-cosmetic-variant.py
/scripts/make-missing-variant.py
/scripts/make-final-test-variant.py
/scripts/final-check.ts
